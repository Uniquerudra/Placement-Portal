{
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/build",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "unsafe-none"
                },
                {
                    "key": "Cross-Origin-Resource-Policy",
                    "value": "cross-origin"
                }
            ]
        }
    ],
    "env": {
        "REACT_APP_API_URL": "https://portal-1tpo-backend.onrender.com/api",
        "REACT_APP_BACKEND_ORIGIN": "https://portal-1tpo-backend.onrender.com",
        "REACT_APP_GOOGLE_CLIENT_ID": "270933402517-i0hvrvgfvtn0sh2rk3d24p6066hbu1qc.apps.googleusercontent.com"
    }
}